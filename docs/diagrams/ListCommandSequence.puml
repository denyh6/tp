@startuml ListCommandSequence
skinparam style strictuml
actor User

participant ":App" as App
participant ":Parser" as Parser
participant ":ListCommand" as ListCommand
participant ":StudentDatabase" as StudentDatabase
participant ":Student" as Student
participant ":Ui" as Ui

User -> App : enter "list"
activate App
App -> Parser : parse(input)
activate Parser
Parser -> ListCommand ** : create()
activate ListCommand
ListCommand -->> Parser
deactivate ListCommand
Parser -->> App : listCommand
deactivate Parser
App -> ListCommand : execute(db, storage)
activate ListCommand
ListCommand -> StudentDatabase : getAllStudents()
activate StudentDatabase
StudentDatabase -->> ListCommand : students
deactivate StudentDatabase

alt students is empty
    ListCommand -->> App : commandResult("No students found.")
else students present
    loop for each student
        ListCommand -> Student : toString()
        activate Student
        Student -->> ListCommand : studentString
        deactivate Student
    end
    ListCommand -->> App : commandResult(formattedList)
end
deactivate ListCommand

App -> Ui : show(result.getMessage())
activate Ui
Ui -->> User : display student list
deactivate Ui
deactivate App
@enduml
