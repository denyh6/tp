@startuml EditCommand_Sequence

skinparam style strictuml

actor User
participant ":App" as App
participant ":Parser" as Parser
participant ":EditCommand" as EditCommand
participant ":StudentDatabase" as StudentDatabase
participant ":Student" as Student
participant "Student.Builder:Builder" as StudentBuilder
participant ":Module" as Module
participant ":Storage" as Storage
participant ":CommandResult" as CommandResult

User -> App : input "edit <index> [fields]"
activate App

App -> Parser : parse(input)
activate Parser

Parser -> EditCommand : new EditCommand(index, name, phone,\nemail, address, course, moduleCode, grade)
activate EditCommand
EditCommand -->> Parser : editCommand
deactivate EditCommand

Parser -->> App : editCommand
deactivate Parser

App -> EditCommand : execute(db, storage)
activate EditCommand

EditCommand -> StudentDatabase : getStudentCount()
activate StudentDatabase
StudentDatabase --> EditCommand : studentCount
deactivate StudentDatabase

alt index out of range
  EditCommand -> CommandResult : new CommandResult("Index should be within range.")
  activate CommandResult
  CommandResult -->> EditCommand : result
  deactivate CommandResult

  EditCommand -->> App : result
else index valid
  EditCommand -> StudentDatabase : getStudent(index)
  activate StudentDatabase
  StudentDatabase -->> EditCommand : existing (Student)
  deactivate StudentDatabase



  opt moduleCode != null
    EditCommand -> Student : getModules()
    activate Student
    Student -->> EditCommand : List<Module>
    deactivate Student

    EditCommand -> EditCommand : check moduleCode exists in list
    activate EditCommand

    opt module not found
      EditCommand -> CommandResult : new CommandResult("Module not found.")
      activate CommandResult
      CommandResult -->> EditCommand : result
      deactivate CommandResult

      EditCommand -->> App : result
    end
    deactivate EditCommand
  end

  EditCommand -> StudentBuilder : new Builder(existing)
  activate StudentBuilder

  EditCommand -> StudentBuilder : name(name)
  EditCommand -> StudentBuilder : phone(phone)
  EditCommand -> StudentBuilder : email(email)
  EditCommand -> StudentBuilder : address(address)
  EditCommand -> StudentBuilder : course(course)
  EditCommand -> StudentBuilder : build()

  StudentBuilder -> Student : new Student(builder)
  activate Student
  Student -->> StudentBuilder : updatedStudent
  deactivate Student

  StudentBuilder -->> EditCommand : updatedStudent
  deactivate StudentBuilder

  loop for each Module in existing.getModules()
    alt moduleCode matches module code
      EditCommand -> Module : new Module(code, newGrade)
      activate Module
      Module -->> EditCommand : updatedModule
      deactivate Module

      EditCommand -> Student : addModule(updatedModule)
      activate Student
      Student -->> EditCommand
      deactivate Student
    else
      EditCommand -> Student : addModule(existingModule)
      activate Student
      Student -->> EditCommand
      deactivate Student
    end
  end

  EditCommand -> StudentDatabase : updateStudent(index, updatedStudent)
  activate StudentDatabase
  StudentDatabase -->> EditCommand
  deactivate StudentDatabase

  EditCommand -> Storage : saveStudentList(db)
  activate Storage
  Storage -->> EditCommand
  deactivate Storage

  EditCommand -> CommandResult : new CommandResult("Student updated successfully.")
  activate CommandResult
  CommandResult -->> EditCommand : result
  deactivate CommandResult

  EditCommand -->> App : result
end
deactivate EditCommand
@enduml