@startuml
skinparam maxMessageSize 150

participant Caller
participant "history:CommandHistory" as CommandHistory
participant "cmd:CreateCommand" as CreateCommand
participant "db:StudentDatabase" as StudentDatabase

Caller -> CommandHistory : pop()
activate CommandHistory
CommandHistory --> Caller : cmd
deactivate CommandHistory

Caller -> CreateCommand : undo(db, storage)
activate CreateCommand

alt createdIndex == -1
    CreateCommand --> Caller : throws CommandException("Cannot undo: create command was not executed")
else createdIndex >= db.getStudentCount()
    CreateCommand -> StudentDatabase : getStudentCount()
    activate StudentDatabase
    StudentDatabase --> CreateCommand : count
    deactivate StudentDatabase
    CreateCommand --> Caller : throws CommandException("Cannot undo: student no longer exists...")
end

CreateCommand -> StudentDatabase : removeStudent(createdIndex)
activate StudentDatabase
StudentDatabase --> CreateCommand : removedStudent
deactivate StudentDatabase

create "result:CommandResult" as CommandResult
CreateCommand -> CommandResult : new("Undone: Student creation of " + removed.getName())
activate CommandResult
CommandResult --> CreateCommand : result
deactivate CommandResult

CreateCommand --> Caller : result
deactivate CreateCommand
@enduml