@startuml

skinparam style strictuml

actor User
participant ":SearchCommand" as SC
participant "db:StudentDatabase" as DB
participant "student:Student" as S
participant "m:Module" as M

User -> SC : execute(db, storage)
activate SC

SC -> DB : getAllStudents()
activate DB
DB -->> SC : List<Student> students
deactivate DB

loop for each student in students
    alt course != null
        SC -> S : getCourse()
        activate S
        S -->> SC : courseName
        deactivate S

        opt courseName contains search string
            SC -> S : getName()
            activate S
            S -->> SC : name
            deactivate S
        end

    else moduleCode != null
        SC -> S : getModules()
        activate S
        S -->> SC : List<Module>
        deactivate S

        loop for each module in student
            SC -> M : getCode()
            activate M
            M -->> SC : code
            deactivate M

            opt code contains moduleCode
                SC -> S : getName()
                activate S
                S -->> SC : name
                deactivate S

                SC -> M : getGrade()
                activate M
                M -->> SC : grade
                deactivate M
            end
        end
    end
end

create participant "result:CommandResult" as CR
SC -> CR : new CommandResult(feedback, false)
activate CR
CR -->> SC
deactivate CR

SC -->> User : result
deactivate SC
@enduml