@startuml DeleteCommandSequence
skinparam style strictuml
actor User

participant ":App" as App
participant ":Parser" as Parser
participant ":DeleteCommand" as DeleteCommand
participant ":StudentDatabase" as StudentDatabase
participant ":Storage" as Storage
participant ":Ui" as Ui

User -> App : enter "delete 1"
activate App
App -> Parser : parse(input)
activate Parser
Parser -> Parser : parseDelete("1")
activate Parser
Parser -> DeleteCommand ** : create(1)
activate DeleteCommand
DeleteCommand -->> Parser
deactivate DeleteCommand
deactivate Parser
Parser -->> App : deleteCommand
deactivate Parser

App -> DeleteCommand : execute(db, storage)
activate DeleteCommand

alt index out of bounds
    DeleteCommand -> DeleteCommand : throw CommandException
    DeleteCommand -->> App : exception
    deactivate DeleteCommand
    App -> Ui : show("Error: " + message)
    activate Ui
    Ui -->> User : display error
    deactivate Ui
else valid index
    DeleteCommand -> StudentDatabase : removeStudent(0)
    activate StudentDatabase
    StudentDatabase -->> DeleteCommand : deletedStudent
    deactivate StudentDatabase
    DeleteCommand -> Storage : saveStudentList(db)
    activate Storage
    Storage -->> DeleteCommand
    deactivate Storage
    DeleteCommand -->> App : commandResult
    deactivate DeleteCommand
    App -> Ui : show(result.getMessage())
    activate Ui
    Ui -->> User : display confirmation
    deactivate Ui
end
deactivate App
@enduml
