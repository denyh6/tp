@startuml FindCommand_Sequence

skinparam style strictuml

actor User
participant ":App" as App
participant ":Parser" as Parser
participant ":FindCommand" as FindCommand
participant ":StudentDatabase" as StudentDatabase
participant ":Student" as Student
participant ":CommandResult" as CommandResult

User -> App : input "find <substring>"
activate App

App -> Parser : parse(input)
activate Parser

Parser -> FindCommand : new FindCommand(substring)
activate FindCommand
FindCommand -->> Parser : findCommand
deactivate FindCommand

Parser -->> App : findCommand
deactivate Parser

App -> FindCommand : execute(db, storage)
activate FindCommand

FindCommand -> StudentDatabase : getAllStudents()
activate StudentDatabase
StudentDatabase -->> FindCommand : List<Student>
deactivate StudentDatabase

loop for each Student in list
  FindCommand -> Student : getName()
  activate Student
  Student -->> FindCommand : name
  deactivate Student

  FindCommand -> Student : getPhone()
  activate Student
  Student -->> FindCommand : phone
  deactivate Student

  FindCommand -> Student : getEmail()
  activate Student
  Student -->> FindCommand : email
  deactivate Student

  FindCommand -> Student : getAddress()
  activate Student
  Student -->> FindCommand : address
  deactivate Student

  FindCommand -> Student : getCourse()
  activate Student
  Student -->> FindCommand : course
  deactivate Student
end

alt match(es) found
  FindCommand -> CommandResult : new CommandResult(resultString, false)
  activate CommandResult
  CommandResult -->> FindCommand : result
  deactivate CommandResult
else no matches
  FindCommand -> CommandResult : new CommandResult("No matching students found.")
  activate CommandResult
  CommandResult -->> FindCommand : result
  deactivate CommandResult
end

FindCommand -->> App : result
deactivate FindCommand

App -> User : Ui.show(result.getMessage())
deactivate App

@endum1